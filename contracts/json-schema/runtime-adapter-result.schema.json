{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-adapter-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome"],
  "properties": {
    "outcome": {
      "enum": ["success", "invalid_output", "runtime_error", "interrupted", "cancelled"]
    },
    "output": {
      "$ref": "./agent-json.defs.schema.json#/$defs/output"
    },
    "output_text": {
      "type": "string"
    },
    "output_json": {
      "type": "object"
    },
    "native_session_handle": {
      "$ref": "./agent-json.defs.schema.json#/$defs/jsonValue"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "$ref": "./agent-json.defs.schema.json#/$defs/jsonValue"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "success"
          }
        }
      },
      "then": {
        "required": ["output"],
        "not": {
          "required": ["error"]
        },
        "oneOf": [
          {
            "properties": {
              "output": {
                "properties": {
                  "mode": {
                    "const": "text"
                  }
                }
              }
            },
            "required": ["output_text"],
            "not": {
              "required": ["output_json"]
            }
          },
          {
            "properties": {
              "output": {
                "properties": {
                  "mode": {
                    "const": "json"
                  }
                }
              }
            },
            "required": ["output_json"],
            "not": {
              "required": ["output_text"]
            }
          }
        ]
      }
    },
    {
      "if": {
        "not": {
          "properties": {
            "outcome": {
              "const": "success"
            }
          }
        }
      },
      "then": {
        "required": ["error"],
        "not": {
          "anyOf": [
            { "required": ["output"] },
            { "required": ["output_text"] },
            { "required": ["output_json"] }
          ]
        }
      }
    }
  ]
}

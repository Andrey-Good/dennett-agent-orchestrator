{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-source-inspection-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_id", "availability", "limit_status"],
  "properties": {
    "source_id": {
      "type": "string"
    },
    "availability": {
      "enum": ["available", "unavailable", "unknown"]
    },
    "limit_status": {
      "enum": ["ok", "limited", "exhausted", "unknown"]
    },
    "status_message": {
      "type": "string"
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-adapter-event.schema.json",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "payload"],
      "properties": {
        "kind": {
          "const": "comment"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "payload"],
      "properties": {
        "kind": {
          "const": "user_chat_request"
        },
        "payload": {
          "$ref": "./orchestrator-user-chat-mcp-request.schema.json"
        }
      }
    }
  ]
}

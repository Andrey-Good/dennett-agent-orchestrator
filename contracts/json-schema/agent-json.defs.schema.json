{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "agent-json.defs.schema.json",
	"$defs": {
		"jsonValue": {
			"oneOf": [
				{ "type": "string" },
				{ "type": "number" },
				{ "type": "boolean" },
				{ "type": "null" },
				{ "$ref": "#/$defs/jsonObject" },
				{ "$ref": "#/$defs/jsonArray" }
			]
		},
		"jsonObject": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/$defs/jsonValue"
			}
		},
		"jsonObjectSchema": {
			"type": "object",
			"additionalProperties": true,
			"required": ["type"],
			"properties": {
				"type": {
					"const": "object"
				}
			}
		},
		"jsonArray": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/jsonValue"
			}
		},
		"meta": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "name"],
			"properties": {
				"id": { "type": "string" },
				"name": { "type": "string" },
				"description": { "type": "string" },
				"agent_version": { "type": "string" }
			}
		},
		"stringParamConstraints": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"min_length": { "type": "integer", "minimum": 0 },
				"max_length": { "type": "integer", "minimum": 0 },
				"pattern": { "type": "string" }
			}
		},
		"numberParamConstraints": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"minimum": { "type": "number" },
				"maximum": { "type": "number" }
			}
		},
		"arrayParamConstraints": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"min_items": { "type": "integer", "minimum": 0 },
				"max_items": { "type": "integer", "minimum": 0 }
			}
		},
		"stringParamDescriptor": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "required"],
			"properties": {
				"type": { "const": "string" },
				"required": { "type": "boolean" },
				"default": { "type": "string" },
				"description": { "type": "string" },
				"mutable_in_ui": { "type": "boolean", "default": true },
				"allowed_values": {
					"type": "array",
					"$comment": "Uniqueness is enforced in the invariant/test layer because portable JSON Schema cannot deep-compare arbitrary JSON values reliably across all item types.",
					"items": { "type": "string" },
					"minItems": 1
				},
				"constraints": {
					"$ref": "#/$defs/stringParamConstraints"
				}
			}
		},
		"numberParamDescriptor": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "required"],
			"properties": {
				"type": { "const": "number" },
				"required": { "type": "boolean" },
				"default": { "type": "number" },
				"description": { "type": "string" },
				"mutable_in_ui": { "type": "boolean", "default": true },
				"allowed_values": {
					"type": "array",
					"$comment": "Uniqueness is enforced in the invariant/test layer because portable JSON Schema cannot deep-compare arbitrary JSON values reliably across all item types.",
					"items": { "type": "number" },
					"minItems": 1
				},
				"constraints": {
					"$ref": "#/$defs/numberParamConstraints"
				}
			}
		},
		"booleanParamDescriptor": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "required"],
			"properties": {
				"type": { "const": "boolean" },
				"required": { "type": "boolean" },
				"default": { "type": "boolean" },
				"description": { "type": "string" },
				"mutable_in_ui": { "type": "boolean", "default": true },
				"allowed_values": {
					"type": "array",
					"items": { "type": "boolean" },
					"minItems": 1,
					"maxItems": 2
				}
			}
		},
		"objectParamDescriptor": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "required"],
			"properties": {
				"type": { "const": "object" },
				"required": { "type": "boolean" },
				"default": { "$ref": "#/$defs/jsonObject" },
				"description": { "type": "string" },
				"mutable_in_ui": { "type": "boolean", "default": true },
				"allowed_values": {
					"type": "array",
					"$comment": "Uniqueness is enforced in the invariant/test layer because portable JSON Schema cannot deep-compare arbitrary JSON values reliably across all item types.",
					"items": { "$ref": "#/$defs/jsonObject" },
					"minItems": 1
				}
			}
		},
		"arrayParamDescriptor": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "required"],
			"properties": {
				"type": { "const": "array" },
				"required": { "type": "boolean" },
				"default": { "$ref": "#/$defs/jsonArray" },
				"description": { "type": "string" },
				"mutable_in_ui": { "type": "boolean", "default": true },
				"allowed_values": {
					"type": "array",
					"$comment": "Uniqueness is enforced in the invariant/test layer because portable JSON Schema cannot deep-compare arbitrary JSON values reliably across all item types.",
					"items": { "$ref": "#/$defs/jsonArray" },
					"minItems": 1
				},
				"constraints": {
					"$ref": "#/$defs/arrayParamConstraints"
				}
			}
		},
		"nullParamDescriptor": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "required"],
			"properties": {
				"type": { "const": "null" },
				"required": { "type": "boolean" },
				"default": { "const": null },
				"description": { "type": "string" },
				"mutable_in_ui": { "type": "boolean", "default": true },
				"allowed_values": {
					"type": "array",
					"items": { "const": null },
					"minItems": 1,
					"maxItems": 1
				}
			}
		},
		"paramDescriptor": {
			"oneOf": [
				{ "$ref": "#/$defs/stringParamDescriptor" },
				{ "$ref": "#/$defs/numberParamDescriptor" },
				{ "$ref": "#/$defs/booleanParamDescriptor" },
				{ "$ref": "#/$defs/objectParamDescriptor" },
				{ "$ref": "#/$defs/arrayParamDescriptor" },
				{ "$ref": "#/$defs/nullParamDescriptor" }
			]
		},
		"params": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/$defs/paramDescriptor"
			}
		},
		"initialVars": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/$defs/jsonValue"
			}
		},
		"skillBinding": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id"],
			"properties": {
				"id": { "type": "string" },
				"codex_ref": { "type": "string" },
				"inline_text": { "type": "string" },
				"frozen": { "type": "boolean", "default": false }
			},
			"allOf": [
				{
					"anyOf": [{ "required": ["codex_ref"] }, { "required": ["inline_text"] }]
				},
				{
					"if": {
						"required": ["frozen"],
						"properties": { "frozen": { "const": true } }
					},
					"then": { "required": ["inline_text"] }
				}
			]
		},
		"skills": {
			"type": "array",
			"$comment": "Each item must be structurally valid, but uniqueness of skillBinding.id across items is enforced by the invariant/test layer because portable JSON Schema cannot express object-field uniqueness across an array.",
			"items": {
				"$ref": "#/$defs/skillBinding"
			}
		},
		"mcpBinding": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "codex_ref"],
			"properties": {
				"id": { "type": "string" },
				"codex_ref": { "type": "string" },
				"config": { "type": "object" }
			}
		},
		"mcps": {
			"type": "array",
			"$comment": "Each item must be structurally valid, but uniqueness of mcpBinding.id across items is enforced by the invariant/test layer because portable JSON Schema cannot express object-field uniqueness across an array.",
			"items": {
				"$ref": "#/$defs/mcpBinding"
			}
		},
		"pluginBinding": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "codex_ref"],
			"properties": {
				"id": { "type": "string" },
				"codex_ref": { "type": "string" },
				"config": { "type": "object" }
			}
		},
		"plugins": {
			"type": "array",
			"$comment": "Each item must be structurally valid, but uniqueness of pluginBinding.id across items is enforced by the invariant/test layer because portable JSON Schema cannot express object-field uniqueness across an array.",
			"items": {
				"$ref": "#/$defs/pluginBinding"
			}
		},
		"permissions": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"profile": { "type": "string" },
				"allow": {
					"type": "array",
					"items": { "type": "string" }
				},
				"deny": {
					"type": "array",
					"items": { "type": "string" }
				},
				"extra": { "type": "object" }
			}
		},
		"finalOutput": {
			"type": "object",
			"additionalProperties": false,
			"required": ["mode"],
			"properties": {
				"mode": {
					"enum": ["last_node_output", "none"]
				}
			}
		},
		"memoryCapabilityToken": {
			"enum": [
				"read",
				"write",
				"entity_scoped",
				"user_scoped",
				"group_scoped",
				"session_scoped",
				"graph_context",
				"temporal_index",
				"profile_synthesis",
				"rag_retrieval",
				"infer_extract",
				"versioned_write",
				"mcp_transport"
			]
		},
		"memoryTransportToken": {
			"enum": ["api", "sdk", "mcp"]
		},
		"memoryBindingIntent": {
			"type": "object",
			"additionalProperties": false,
			"required": ["summary"],
			"properties": {
				"summary": {
					"type": "string",
					"minLength": 1
				},
				"labels": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				}
			}
		},
		"memoryBindingTransportPreferences": {
			"type": "object",
			"$comment": "The schema can enforce valid token arrays and uniqueness within each list, but overlap between preferred and forbid is enforced in the invariant/runtime layer.",
			"additionalProperties": false,
			"properties": {
				"preferred": {
					"type": "array",
					"items": { "$ref": "#/$defs/memoryTransportToken" },
					"uniqueItems": true
				},
				"forbid": {
					"type": "array",
					"items": { "$ref": "#/$defs/memoryTransportToken" },
					"uniqueItems": true
				}
			}
		},
		"memoryBindingProviderExtension": {
			"type": "object",
			"additionalProperties": false,
			"required": ["provider"],
			"properties": {
				"provider": { "type": "string", "minLength": 1 },
				"transport": { "$ref": "#/$defs/memoryTransportToken" },
				"config": { "$ref": "#/$defs/jsonObject" }
			},
			"allOf": [
				{
					"if": {
						"properties": {
							"provider": { "const": "mem0" }
						},
						"required": ["provider"]
					},
					"then": {
						"properties": {
							"config": { "$ref": "#/$defs/mem0ProviderExtensionConfig" }
						}
					}
				}
			]
		},
		"mem0ProviderExtensionConfig": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"mem0_config": { "$ref": "#/$defs/mem0PortableOverrideConfig" }
			}
		},
		"mem0PortableOverrideConfig": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"graph_store": { "$ref": "#/$defs/mem0GraphStorePortableOverride" }
			}
		},
		"emptyObject": {
			"type": "object",
			"additionalProperties": false,
			"maxProperties": 0
		},
		"mem0GraphStorePortableOverride": {
			"type": "object",
			"additionalProperties": false,
			"required": ["provider"],
			"properties": {
				"provider": { "type": "string", "minLength": 1 },
				"config": { "$ref": "#/$defs/emptyObject" }
			}
		},
		"memoryBindingConfig": {
			"type": "object",
			"additionalProperties": false,
			"required": ["intent", "required_capabilities"],
			"properties": {
				"intent": { "$ref": "#/$defs/memoryBindingIntent" },
				"required_capabilities": {
					"type": "array",
					"items": { "$ref": "#/$defs/memoryCapabilityToken" },
					"uniqueItems": true
				},
				"transport_preferences": {
					"$ref": "#/$defs/memoryBindingTransportPreferences"
				},
				"provider_extension": {
					"$ref": "#/$defs/memoryBindingProviderExtension"
				},
				"local_notes": { "type": "string" }
			}
		},
		"memoryBinding": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "kind", "codex_ref", "config", "scope"],
			"properties": {
				"id": { "type": "string" },
				"kind": {
					"const": "runtime_memory"
				},
				"codex_ref": { "type": "string" },
				"config": { "$ref": "#/$defs/memoryBindingConfig" },
				"scope": {
					"enum": ["agent", "node"]
				}
			}
		},
		"memoryBindings": {
			"type": "array",
			"$comment": "Each item must be structurally valid, but uniqueness of memoryBinding.id across items is enforced by the invariant/test layer because portable JSON Schema cannot express object-field uniqueness across an array.",
			"items": {
				"$ref": "#/$defs/memoryBinding"
			}
		},
		"runtimeSource": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "runtime_adapter", "source_ref"],
			"properties": {
				"id": { "type": "string" },
				"runtime_adapter": { "type": "string" },
				"source_ref": { "type": "string" },
				"description": { "type": "string" }
			}
		},
		"runtimeSources": {
			"type": "array",
			"$comment": "Each item must be structurally valid, but uniqueness of runtimeSource.id across items is enforced by the invariant/test layer because portable JSON Schema cannot express object-field uniqueness across an array.",
			"items": {
				"$ref": "#/$defs/runtimeSource"
			}
		},
		"comments": {
			"type": "object",
			"additionalProperties": false,
			"required": ["enabled"],
			"properties": {
				"enabled": { "type": "boolean" },
				"target_node_ids": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				}
			},
			"allOf": [
				{
					"if": { "properties": { "enabled": { "const": true } } },
					"then": {
						"required": ["target_node_ids"],
						"properties": {
							"target_node_ids": { "minItems": 1 }
						}
					}
				}
			]
		},
		"userMcp": {
			"type": "object",
			"additionalProperties": false,
			"required": ["enabled"],
			"properties": {
				"enabled": { "type": "boolean" },
				"server_name": {
					"type": "string",
					"const": "orchestrator.user_chat"
				}
			}
		},
		"interaction": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"comments": {
					"$ref": "#/$defs/comments"
				},
				"user_mcp": {
					"$ref": "#/$defs/userMcp"
				}
			}
		},
		"secretMarkers": {
			"type": "object",
			"$comment": "The schema can require both marker strings to exist and be non-empty, but it cannot portably enforce open_marker != close_marker; that inequality is checked in the invariant/test layer.",
			"additionalProperties": false,
			"required": ["enabled"],
			"properties": {
				"enabled": { "type": "boolean" },
				"open_marker": {
					"type": "string",
					"minLength": 1,
					"default": "[[SECRET]]"
				},
				"close_marker": {
					"type": "string",
					"minLength": 1,
					"default": "[[/SECRET]]"
				}
			}
		},
		"chat": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"prefer_native_resume": { "type": "boolean", "default": true },
				"store_visible_messages": { "type": "boolean", "default": true },
				"store_context_window": { "type": "boolean", "default": true },
				"allow_fresh_start": { "type": "boolean", "default": true },
				"secret_markers": {
					"$ref": "#/$defs/secretMarkers"
				}
			}
		},
		"inputPartText": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "text"],
			"properties": {
				"type": { "const": "text" },
				"text": { "type": "string" }
			}
		},
		"inputPartRef": {
			"type": "object",
			"additionalProperties": false,
			"required": ["type", "ref"],
			"properties": {
				"type": { "const": "ref" },
				"ref": { "type": "string" }
			}
		},
		"inputPart": {
			"oneOf": [
				{
					"$ref": "#/$defs/inputPartText"
				},
				{
					"$ref": "#/$defs/inputPartRef"
				}
			]
		},
		"input": {
			"type": "object",
			"additionalProperties": false,
			"required": ["parts"],
			"properties": {
				"parts": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/inputPart"
					}
				}
			}
		},
		"textOutput": {
			"type": "object",
			"additionalProperties": false,
			"required": ["mode"],
			"properties": {
				"mode": {
					"const": "text"
				}
			}
		},
		"jsonOutput": {
			"type": "object",
			"additionalProperties": false,
			"required": ["mode", "schema"],
			"properties": {
				"mode": {
					"const": "json"
				},
				"schema": {
					"$ref": "#/$defs/jsonObjectSchema"
				}
			}
		},
		"output": {
			"oneOf": [
				{
					"$ref": "#/$defs/textOutput"
				},
				{
					"$ref": "#/$defs/jsonOutput"
				}
			]
		},
		"runtimeAgentNode": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "kind", "input", "output", "runtime_adapter", "prompt"],
			"properties": {
				"id": { "type": "string" },
				"title": { "type": "string" },
				"kind": { "const": "runtime_agent" },
				"input": {
					"$ref": "#/$defs/input"
				},
				"output": {
					"$ref": "#/$defs/output"
				},
				"runtime_adapter": { "type": "string" },
				"prompt": { "type": "string" },
				"skill_ids": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				},
				"mcp_ids": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				},
				"plugin_ids": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				},
				"memory_ids": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				},
				"permissions": {
					"$ref": "#/$defs/permissions"
				},
				"runtime_options": { "type": "object" },
				"runtime_source_ids": {
					"type": "array",
					"items": { "type": "string" },
					"uniqueItems": true
				},
				"runtime_source_policy": {
					"enum": ["inherit", "restrict", "prefer_first"]
				}
			},
			"allOf": [
				{
					"if": {
						"not": {
							"required": ["runtime_source_policy"]
						}
					},
					"then": {
						"not": {
							"required": ["runtime_source_ids"]
						}
					}
				},
				{
					"if": {
						"properties": {
							"runtime_source_policy": {
								"const": "inherit"
							}
						}
					},
					"then": {
						"not": {
							"required": ["runtime_source_ids"]
						}
					}
				},
				{
					"if": {
						"required": ["runtime_source_policy"],
						"properties": {
							"runtime_source_policy": {
								"enum": ["restrict", "prefer_first"]
							}
						}
					},
					"then": {
						"required": ["runtime_source_ids"],
						"properties": {
							"runtime_source_ids": {
								"minItems": 1
							}
						}
					}
				}
			]
		},
		"orchestratorAgentNode": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "kind", "input", "output", "agent_ref"],
			"properties": {
				"id": { "type": "string" },
				"title": { "type": "string" },
				"kind": { "const": "orchestrator_agent" },
				"input": {
					"$ref": "#/$defs/input"
				},
				"output": {
					"$ref": "#/$defs/output"
				},
				"agent_ref": { "type": "string" }
			}
		},
		"node": {
			"oneOf": [
				{
					"$ref": "#/$defs/runtimeAgentNode"
				},
				{
					"$ref": "#/$defs/orchestratorAgentNode"
				}
			]
		},
		"nodes": {
			"type": "array",
			"minItems": 1,
			"$comment": "Each node must match one of the node shapes here, but uniqueness of node.id across the array is enforced by the invariant/test layer because portable JSON Schema cannot express object-field uniqueness across an array.",
			"items": {
				"$ref": "#/$defs/node"
			}
		},
		"edgeCondition": {
			"type": "object",
			"additionalProperties": false,
			"required": ["code"],
			"properties": {
				"code": { "type": "string" }
			}
		},
		"edge": {
			"type": "object",
			"additionalProperties": false,
			"required": ["from", "to"],
			"properties": {
				"from": { "type": "string" },
				"to": { "type": "string" },
				"condition": {

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dennett.local/schemas/autonomous-batch.schema.json",
  "title": "Dennett Autonomous Batch",
  "type": "object",
  "required": [
    "version",
    "id",
    "title",
    "status",
    "packages",
    "execution",
    "limits",
    "stop_conditions",
    "reporting"
  ],
  "properties": {
    "version": {"const": 1},
    "id": {"type": "string", "pattern": "^AB-M[0-9]{2}-[0-9]{3}$"},
    "title": {"type": "string", "minLength": 5},
    "status": {
      "enum": ["DRAFT", "READY", "RUNNING", "PAUSED", "COMPLETED", "BLOCKED", "CANCELLED"]
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^WP-M[0-9]{2}-[0-9]{3}$"}
    },
    "execution": {
      "type": "object",
      "required": [
        "order",
        "max_parallel",
        "stop_after_packages",
        "merge_after_each",
        "require_green_main"
      ],
      "properties": {
        "order": {"enum": ["dependency", "listed"]},
        "max_parallel": {"type": "integer", "minimum": 1},
        "stop_after_packages": {"type": "integer", "minimum": 1},
        "merge_after_each": {"type": "boolean"},
        "require_green_main": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "required": [
        "max_risk",
        "new_production_dependencies",
        "architecture_changes",
        "external_effects",
        "public_breaking_changes"
      ],
      "properties": {
        "max_risk": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
        "new_production_dependencies": {"type": "string", "minLength": 1},
        "architecture_changes": {"type": "string", "minLength": 1},
        "external_effects": {"type": "string", "minLength": 1},
        "public_breaking_changes": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "reporting": {
      "type": "object",
      "required": ["on_package_start", "on_package_end", "on_decision", "periodic_noise"],
      "properties": {
        "on_package_start": {"type": "boolean"},
        "on_package_end": {"type": "boolean"},
        "on_decision": {"type": "boolean"},
        "periodic_noise": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

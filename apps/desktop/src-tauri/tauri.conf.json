{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dennett",
  "version": "0.1.0",
  "identifier": "dev.dennett.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dennett",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true
  }
}

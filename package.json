{
  "name": "dennett-workspace",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "docs:check": "python tools/verify_docs.py",
    "repo:check": "python tools/verify_repo.py && python tools/verify_planning.py",
    "planning:check": "python tools/verify_planning.py"
  }
}

{
  "graph_contract_version": "1.0",
  "meta": {
    "id": "params-constrained-values",
    "name": "Constrained Params"
  },
  "entry_node_id": "start",
  "params": {
    "model_profile": {
      "type": "string",
      "required": true,
      "default": "gpt-5.3-codex",
      "allowed_values": [
        "gpt-5.3-codex",
        "gpt-5.4-mini-codex"
      ],
      "constraints": {
        "min_length": 3,
        "max_length": 32,
        "pattern": "^[a-z0-9.-]+$"
      }
    },
    "review_count": {
      "type": "number",
      "required": true,
      "default": 2,
      "allowed_values": [
        1,
        2,
        3
      ],
      "constraints": {
        "minimum": 1,
        "maximum": 3
      }
    }
  },
  "nodes": [
    {
      "id": "start",
      "kind": "runtime_agent",
      "runtime_adapter": "codex",
      "prompt": "Use the configured review count.",
      "input": {
        "parts": [
          {
            "type": "text",
            "text": "Profile: "
          },
          {
            "type": "ref",
            "ref": "params.model_profile"
          }
        ]
      },
      "output": {
        "mode": "text"
      }
    }
  ]
}

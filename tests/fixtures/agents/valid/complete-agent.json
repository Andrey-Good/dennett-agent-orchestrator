{
	"graph_contract_version": "1.0",
	"meta": {
		"id": "stage3-complete-agent",
		"name": "Stage 3 Complete Agent",
		"description": "Portable contract coverage fixture.",
		"agent_version": "2026.04.22"
	},
	"entry_node_id": "triage",
	"params": {
		"ticket_id": {
			"type": "string",
			"required": true,
			"default": "TASK-123"
		}
	},
	"initial_vars": {
		"seed": "stable"
	},
	"skills": [
		{
			"id": "triage_skill",
			"codex_ref": "skills/triage.md"
		},
		{
			"id": "handoff_style",
			"inline_text": "Hand off clearly.",
			"frozen": true
		}
	],
	"mcps": [
		{
			"id": "repo_docs",
			"codex_ref": "mcp/repo-docs"
		}
	],
	"plugins": [
		{
			"id": "github_plugin",
			"codex_ref": "plugins/github"
		}
	],
	"permissions": {
		"profile": "workspace-write"
	},
	"interaction": {
		"comments": {
			"enabled": true,
			"target_node_ids": ["triage"]
		},
		"user_mcp": {
			"enabled": true,
			"server_name": "orchestrator.user_chat"
		}
	},
	"chat": {
		"prefer_native_resume": true,
		"store_visible_messages": true,
		"store_context_window": true,
		"allow_fresh_start": true,
		"secret_markers": {
			"enabled": true,
			"open_marker": "[[SECRET]]",
			"close_marker": "[[/SECRET]]"
		}
	},
	"final_output": {
		"mode": "last_node_output"
	},
	"memory_bindings": [
		{
			"id": "memory_agent",
			"kind": "runtime_memory",
			"codex_ref": "memory/main",
			"config": {
				"intent": {
					"summary": "Primary shared memory binding for the complete portable contract fixture.",
					"labels": ["shared", "retrieval"]
				},
				"required_capabilities": ["read", "write"],
				"transport_preferences": {
					"preferred": ["api"]
				}
			},
			"scope": "agent"
		}
	],
	"runtime_sources": [
		{
			"id": "primary_codex",
			"runtime_adapter": "codex",
			"source_ref": "workspace://primary",
			"description": "Primary source"
		}
	],
	"nodes": [
		{
			"id": "triage",
			"kind": "runtime_agent",
			"runtime_adapter": "codex",
			"prompt": "Return a structured triage result.",
			"input": {
				"parts": [
					{
						"type": "text",
						"text": "Ticket: "
					},
					{
						"type": "ref",
						"ref": "params.ticket_id"
					}
				]
			},
			"output": {
				"mode": "json",
				"schema": {
					"type": "object",
					"additionalProperties": true
				}
			},
			"runtime_options": {
				"model": "gpt-5.3-codex",
				"temperature": 0.1
			},
			"runtime_source_policy": "prefer_first",
			"runtime_source_ids": ["primary_codex"]
		},
		{
			"id": "handoff",
			"kind": "orchestrator_agent",
			"agent_ref": "agent.handoff",
			"input": {
				"parts": [
					{
						"type": "text",
						"text": "Delegate the next step."
					}
				]
			},
			"output": {
				"mode": "text"
			}
		}
	],
	"edges": [
		{
			"from": "triage",
			"to": "handoff"
		}
	]
}
